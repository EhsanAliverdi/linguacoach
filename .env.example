# Copy this to .env and fill in real values. Never commit .env.

# Database (shared-postgres on VPS)
DB_HOST=shared-postgres
DB_PORT=5432
DB_NAME=linguacoach
DB_USER=linguacoach
DB_PASSWORD=CHANGE_ME

# JWT — minimum 32 chars, random
JWT_KEY=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ISSUER=linguacoach
JWT_AUDIENCE=linguacoach
JWT_EXPIRY_HOURS=24

# Initial admin account (seeded on first startup, idempotent)
SEED_ADMIN_EMAIL=admin@speakpath.app
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# AI providers — set whichever provider(s) you use. At least one is required in production.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# Listening audio/TTS (Fake provider is used until a real provider is configured)
TTS_PROVIDER=Fake
TTS_ENABLED=true
TTS_AUDIO_STORAGE_PATH=./app-data/audio
TTS_DEFAULT_VOICE=fake-workplace-voice

# Speaking/STT (Fake provider returns a placeholder transcript in MVP)
STT_PROVIDER=Fake
STT_ENABLED=true
STT_MAX_AUDIO_MB=10
SPEAKING_AUDIO_STORAGE_PATH=./app-data/speaking-audio

# Which provider/model handles each feature (defaults to openai/gpt-4o-mini in Development).
# Supported providers: openai | gemini | anthropic
# AI__WritingFeedback__Provider=openai
# AI__WritingFeedback__Model=gpt-4o-mini

# ── File storage (IFileStorageService) ──────────────────────────────────────
# Provider: Local (filesystem, dev) or Minio (S3-compatible object storage, prod).
FILE_STORAGE_PROVIDER=Local
FILE_STORAGE_LOCAL_BASE_PATH=/app/audio

# MinIO / object storage (used when FILE_STORAGE_PROVIDER=Minio).
# Secrets must come from the VPS .env / Docker secrets — never commit real values.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=speakpath
MINIO_SECRET_KEY=CHANGE_ME_STRONG_SECRET
MINIO_BUCKET_NAME=speakpath-audio
MINIO_USE_SSL=false
MINIO_SIGNED_URL_EXPIRY_MINUTES=10

# ── Background generation (Quartz) ──────────────────────────────────────────
BACKGROUND_JOBS_ENABLED=true
LESSON_BUFFER_READY_SIZE=5
LESSON_BUFFER_REFILL_THRESHOLD=1
LESSON_BUFFER_REFILL_BATCH_SIZE=4

# ── Practice Gym ready-exercise buffer ──────────────────────────────────────
PRACTICE_GYM_READY_EXERCISES_PER_TYPE=10
PRACTICE_GYM_REFILL_THRESHOLD_PER_TYPE=3
PRACTICE_GYM_REFILL_COUNT_PER_TYPE=7

# Image tags (set by GitHub Actions, override locally if needed)
API_IMAGE=ghcr.io/ehsanaliverdi/linguacoach-api:latest
WEB_IMAGE=ghcr.io/ehsanaliverdi/linguacoach-web:latest

# Domain
DOMAIN=speakpath.app
