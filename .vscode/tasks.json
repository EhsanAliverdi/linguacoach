{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start: All (Docker + Frontend)",
      "dependsOn": ["Start: Docker (DB + API)", "Start: Frontend"],
      "dependsOrder": "parallel",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Start: Full Stack (Docker)",
      "type": "shell",
      "command": "docker compose up --build",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting",
          "endsPattern": "Attaching to"
        }
      },
      "presentation": {
        "label": "Full Stack",
        "group": "linguacoach",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start: Docker (DB + API)",
      "type": "shell",
      "command": "docker compose up --build db minio api",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting",
          "endsPattern": "Attaching to"
        }
      },
      "presentation": {
        "label": "Docker",
        "group": "linguacoach",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Free: Port 4200",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-Command",
        "$conns = Get-NetTCPConnection -LocalPort 4200 -State Listen -ErrorAction SilentlyContinue; if ($conns) { $conns | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { Write-Host \"Stopping stale process $_ on port 4200\"; Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue } } else { Write-Host 'Port 4200 is already free.' }"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": {
        "label": "Frontend",
        "group": "linguacoach",
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start: Frontend",
      "type": "shell",
      "command": "npm start",
      "options": { "cwd": "${workspaceFolder}/src/LinguaCoach.Web" },
      "isBackground": true,
      "dependsOn": ["Free: Port 4200"],
      "dependsOrder": "sequence",
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Browser bundles",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "label": "Frontend",
        "group": "linguacoach",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Stop: Docker",
      "type": "shell",
      "command": "docker compose down",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": {
        "label": "Docker Stop",
        "group": "linguacoach",
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Stop: Docker + Volumes",
      "type": "shell",
      "command": "docker compose down -v",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": {
        "label": "Docker Stop",
        "group": "linguacoach",
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Test: All",
      "type": "shell",
      "command": "dotnet test",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "problemMatcher": "$msCompile",
      "presentation": {
        "label": "Tests",
        "group": "linguacoach",
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Test: Frontend",
      "type": "shell",
      "command": "npm test -- --watch=false --browsers=ChromeHeadless",
      "options": { "cwd": "${workspaceFolder}/src/LinguaCoach.Web" },
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "label": "Frontend Tests",
        "group": "linguacoach",
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
